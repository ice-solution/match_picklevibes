<!doctype html>
<html lang="zh-HK">
  <head>
    <%- include("../partials/head", { title: "報名成功 - " + tournament.name, tournament }) %>
    <style>
      body { font-family: "Noto Sans TC", system-ui, -apple-system, sans-serif; }
    </style>
  </head>
  <body>
    <%- include("../partials/nav", { tournament }) %>

    <main class="mx-auto max-w-3xl px-4 py-10">
      <div class="overflow-hidden rounded-3xl bg-white ring-1 ring-black/5">
        <div class="bg-gradient-to-br from-pickle-teal via-pickle-yellow to-pickle-pink px-6 py-8 text-white md:px-8">
          <div class="flex items-center gap-3">
            <img
              src="/images/picklevibes-logo.png"
              alt="PickleVibes"
              class="h-12 w-12 rounded-2xl bg-white object-contain ring-1 ring-black/5"
            />
            <div>
              <div class="text-sm font-bold">報名紀錄</div>
              <div class="text-xs text-white/90"><%= tournament.name %></div>
            </div>
          </div>
          <div class="mt-4 text-sm text-white/90">
            <% if (reg && reg.paymentStatus === 'paid') { %>
              付款已完成。請截圖保存此頁。
            <% } else if (reg && reg.paymentStatus === 'skipped') { %>
              此環境未啟用線上付款或金額未設定，報名已記錄。請截圖保存此頁。
            <% } else if (reg && reg.paymentStatus === 'pending') { %>
              <span class="font-semibold">付款處理中或未完成。</span>請返回報名頁重新付款，或聯絡主辦方。
            <% } else { %>
              請截圖保存此頁，主辦方會以電郵跟進確認。
            <% } %>
          </div>
        </div>

        <div class="px-6 py-6 md:px-8 md:py-7">
          <% if (!reg) { %>
            <div class="rounded-2xl bg-red-50 p-4 text-sm text-red-700 ring-1 ring-red-100">
              找不到報名資料。
            </div>
          <% } else { %>
            <dl class="grid gap-3 text-sm">
              <div class="flex items-start justify-between gap-4">
                <dt class="text-black/60">付款狀態</dt>
                <dd class="text-right font-semibold text-pickle-ink">
                  <% if (reg.paymentStatus === 'paid') { %>已付款<% } else if (reg.paymentStatus === 'skipped') { %>略過線上付款<% } else { %>待付款<% } %>
                </dd>
              </div>
              <div class="flex items-start justify-between gap-4">
                <dt class="text-black/60">聯絡人</dt>
                <dd class="text-right font-semibold text-pickle-ink"><%= reg.fullName %></dd>
              </div>
              <div class="flex items-start justify-between gap-4">
                <dt class="text-black/60">電郵</dt>
                <dd class="text-right font-semibold text-pickle-ink"><%= reg.email %></dd>
              </div>
              <% if (reg.bocMemberCode) { %>
                <div class="flex items-start justify-between gap-4">
                  <dt class="text-black/60">BOC 會員代碼</dt>
                  <dd class="text-right font-semibold text-pickle-ink"><%= reg.bocMemberCode %></dd>
                </div>
              <% } %>
              <div class="flex items-start justify-between gap-4">
                <dt class="text-black/60">組別</dt>
                <dd class="text-right text-xs font-semibold text-pickle-ink md:text-sm"><%= reg.division %></dd>
              </div>
              <div class="mt-4 rounded-2xl bg-pickle-mist p-4 ring-1 ring-black/5">
                <div class="text-xs font-semibold text-black/60">球員 1</div>
                <div class="mt-2 grid gap-1 text-sm text-black/80">
                  <div><span class="text-black/50">姓名：</span><%= reg.player1 && reg.player1.name %></div>
                  <div><span class="text-black/50">出生日期：</span><%= reg.player1 && reg.player1.dateOfBirth ? new Date(reg.player1.dateOfBirth).toISOString().slice(0, 10) : '—' %></div>
                  <div><span class="text-black/50">性別：</span><%= reg.player1 && reg.player1.gender === 'male' ? '男' : (reg.player1 && reg.player1.gender === 'female' ? '女' : '—') %></div>
                  <div><span class="text-black/50">DUPR：</span><%= reg.player1 && reg.player1.dupr != null ? Number(reg.player1.dupr).toFixed(2) : '—' %></div>
                </div>
              </div>
              <div class="rounded-2xl bg-pickle-mist p-4 ring-1 ring-black/5">
                <div class="text-xs font-semibold text-black/60">球員 2</div>
                <div class="mt-2 grid gap-1 text-sm text-black/80">
                  <div><span class="text-black/50">姓名：</span><%= reg.player2 && reg.player2.name %></div>
                  <div><span class="text-black/50">出生日期：</span><%= reg.player2 && reg.player2.dateOfBirth ? new Date(reg.player2.dateOfBirth).toISOString().slice(0, 10) : '—' %></div>
                  <div><span class="text-black/50">性別：</span><%= reg.player2 && reg.player2.gender === 'male' ? '男' : (reg.player2 && reg.player2.gender === 'female' ? '女' : '—') %></div>
                  <div><span class="text-black/50">DUPR：</span><%= reg.player2 && reg.player2.dupr != null ? Number(reg.player2.dupr).toFixed(2) : '—' %></div>
                </div>
              </div>
              <div class="flex items-start justify-between gap-4">
                <dt class="text-black/60">日期</dt>
                <dd class="text-right font-semibold text-pickle-ink"><%= reg.tournamentDate %></dd>
              </div>
              <div class="flex items-start justify-between gap-4">
                <dt class="text-black/60">地點</dt>
                <dd class="text-right font-semibold text-pickle-ink"><%= reg.tournamentLocation %></dd>
              </div>
              <% if (reg.notes) { %>
                <div class="mt-2 rounded-2xl bg-pickle-mist p-4 ring-1 ring-black/5">
                  <div class="text-xs font-semibold text-black/60">備註</div>
                  <div class="mt-1 whitespace-pre-wrap text-sm text-black/70"><%= reg.notes %></div>
                </div>
              <% } %>
            </dl>
          <% } %>

          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href="/"
              class="inline-flex items-center justify-center rounded-2xl bg-white px-5 py-3 text-sm font-bold text-pickle-ink ring-1 ring-black/5 hover:bg-black/5"
            >
              返回首頁
            </a>
            <% if (!reg || reg.paymentStatus !== 'pending') { %>
              <a
                href="/apply"
                class="inline-flex items-center justify-center rounded-2xl bg-pickle-pink px-5 py-3 text-sm font-bold text-white shadow-sm hover:brightness-95"
              >
                再報名其他組別
              </a>
            <% } %>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
