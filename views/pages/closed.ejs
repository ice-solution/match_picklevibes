<!doctype html>
<html lang="zh-HK">
  <head>
    <%- include("../partials/head", { title: "報名已截止 - " + tournament.name, tournament }) %>
    <style>
      body { font-family: "Noto Sans TC", system-ui, -apple-system, sans-serif; }
    </style>
  </head>
  <body>
    <%- include("../partials/nav", { tournament }) %>

    <main class="mx-auto max-w-lg px-4 py-16 text-center">
      <div class="rounded-3xl bg-white p-8 ring-1 ring-black/5">
        <h1 class="text-xl font-extrabold text-pickle-ink">報名已截止</h1>
        <% if (registrationDeadline) { %>
          <p class="mt-3 text-sm text-black/70">
            截止時間：<%= new Date(registrationDeadline).toLocaleString("zh-HK", { hour12: false }) %>
          </p>
        <% } %>
        <p class="mt-4 text-sm text-black/60">如有查詢，請聯絡主辦方。</p>
        <a
          href="/"
          class="mt-6 inline-flex items-center justify-center rounded-2xl bg-pickle-teal px-5 py-3 text-sm font-extrabold text-white shadow-sm hover:brightness-95"
        >
          返回首頁
        </a>
      </div>
    </main>
  </body>
</html>
