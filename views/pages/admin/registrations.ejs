<!doctype html>
<html lang="zh-HK">
  <head>
    <%- include("../../partials/head", { title: "後台 - 報名資料 - " + tournament.name, tournament }) %>
    <style>
      body { font-family: "Noto Sans TC", system-ui, -apple-system, sans-serif; }
    </style>
  </head>
  <body>
    <header class="sticky top-0 z-40 border-b border-black/5 bg-white/80 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
        <div class="flex items-center gap-3">
          <img
            src="/images/picklevibes-logo.png"
            alt="PickleVibes"
            class="h-10 w-10 rounded-full bg-white object-contain ring-1 ring-black/5"
          />
          <div>
            <div class="text-sm font-extrabold text-pickle-ink">後台 · 報名資料</div>
            <div class="text-xs text-black/60"><%= tournament.name %></div>
          </div>
        </div>
        <form method="post" action="/admin/logout">
          <button class="rounded-xl px-3 py-2 text-sm font-bold text-pickle-ink hover:bg-black/5" type="submit">
            登出
          </button>
        </form>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-4 py-8">
      <% const showPayPick = typeof stripePaymentOk !== "undefined" && stripePaymentOk; %>
      <% const tableColspan = showPayPick ? 12 : 11; %>
      <form
        id="bulkActionForm"
        method="post"
        action="/admin/registrations/send-payment-emails"
        onsubmit="var n=document.querySelectorAll('.row-pay-cb:checked').length;if(!n){alert('請至少勾選一筆報名。');return false;}return true;"
      >

      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="text-sm text-black/60">
          共 <span class="font-bold text-pickle-ink"><%= total %></span> 筆 · 第 <%= page %> 頁
          <% if (typeof hasActiveFilters !== "undefined" && hasActiveFilters) { %>
            <span class="ml-2 inline-flex items-center rounded-full bg-pickle-teal/15 px-2 py-0.5 text-xs font-bold text-pickle-teal ring-1 ring-pickle-teal/25">已套用篩選</span>
          <% } %>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <% if (showPayPick) { %>
            <button
              type="submit"
              formaction="/admin/registrations/send-payment-emails"
              class="rounded-xl bg-pickle-pink px-3 py-2 text-sm font-extrabold text-white shadow-sm hover:brightness-95"
              onclick="var n=document.querySelectorAll('.row-pay-cb:checked').length;return confirm('確定對已勾選的 '+n+' 筆寄出付款電郵？');"
            >
              對勾選者發送付款電郵
            </button>
            <button
              type="submit"
              formaction="/admin/registrations/send-payment-reminders"
              class="rounded-xl bg-white px-3 py-2 text-sm font-extrabold text-pickle-ink ring-1 ring-black/10 hover:bg-black/5"
              onclick="var n=document.querySelectorAll('.row-pay-cb:checked').length;return confirm('確定對已勾選的 '+n+' 筆寄出付款提醒電郵？');"
            >
              對勾選者發送付款提醒
            </button>
          <% } %>
          <a
            href="/admin/payment-batch"
            class="rounded-xl bg-pickle-teal px-3 py-2 text-sm font-extrabold text-white shadow-sm hover:brightness-95"
          >
            批次付款電郵
          </a>
          <a
            href="/admin/export.xlsx"
            class="rounded-xl bg-white px-3 py-2 text-sm font-extrabold text-pickle-ink ring-1 ring-black/10 hover:bg-black/5"
          >
            匯出 XLSX
          </a>
        </div>
      </div>

      <form method="get" action="/admin" class="mt-4 flex flex-wrap items-end gap-3 rounded-2xl bg-white p-4 ring-1 ring-black/5">
        <div class="min-w-[200px] flex-1">
          <label for="filterDivision" class="mb-1 block text-xs font-bold text-black/50">組別</label>
          <select
            id="filterDivision"
            name="division"
            class="w-full rounded-xl border border-black/10 bg-white px-3 py-2 text-sm font-semibold text-pickle-ink outline-none focus:ring-2 focus:ring-pickle-teal/40"
          >
            <option value="">全部組別</option>
            <% (divisions || []).forEach(function (d) { %>
              <option value="<%= d.value %>" <%= (typeof filterDivision !== "undefined" && filterDivision === d.value) ? "selected" : "" %>><%= d.label %></option>
            <% }); %>
          </select>
        </div>
        <div>
          <label for="filterDateFrom" class="mb-1 block text-xs font-bold text-black/50">提交日期（起）</label>
          <input
            id="filterDateFrom"
            type="date"
            name="dateFrom"
            value="<%= typeof filterDateFrom !== "undefined" ? filterDateFrom : "" %>"
            class="rounded-xl border border-black/10 bg-white px-3 py-2 text-sm text-pickle-ink outline-none focus:ring-2 focus:ring-pickle-teal/40"
          />
        </div>
        <div>
          <label for="filterDateTo" class="mb-1 block text-xs font-bold text-black/50">提交日期（迄）</label>
          <input
            id="filterDateTo"
            type="date"
            name="dateTo"
            value="<%= typeof filterDateTo !== "undefined" ? filterDateTo : "" %>"
            class="rounded-xl border border-black/10 bg-white px-3 py-2 text-sm text-pickle-ink outline-none focus:ring-2 focus:ring-pickle-teal/40"
          />
        </div>
        <div class="flex flex-wrap items-center gap-2 pb-0.5">
          <button type="submit" class="rounded-xl bg-pickle-ink px-4 py-2 text-sm font-extrabold text-white shadow-sm hover:brightness-110">
            套用篩選
          </button>
          <a href="/admin" class="rounded-xl bg-white px-4 py-2 text-sm font-extrabold text-pickle-ink ring-1 ring-black/10 hover:bg-black/5">重設</a>
        </div>
        <p class="w-full text-xs text-black/45">日期以香港時間（GMT+8）計算「提交時間」欄所屬日曆日；僅填「起」或僅填「迄」亦可。</p>
      </form>

      <% if (paymentEmailBatchFlash && paymentEmailBatchFlash.lines && paymentEmailBatchFlash.lines.length) { %>
        <div class="mt-4 rounded-2xl bg-pickle-mist p-4 text-sm text-black/80 ring-1 ring-black/5">
          <div class="font-extrabold text-pickle-ink">批次付款電郵結果</div>
          <ul class="mt-2 list-disc space-y-1 pl-5 text-xs">
            <% paymentEmailBatchFlash.lines.forEach(function (line) { %>
              <li><%= line %></li>
            <% }); %>
          </ul>
        </div>
      <% } %>
      <% if (paymentReminderBatchFlash && paymentReminderBatchFlash.lines && paymentReminderBatchFlash.lines.length) { %>
        <div class="mt-4 rounded-2xl bg-pickle-mist p-4 text-sm text-black/80 ring-1 ring-black/5">
          <div class="font-extrabold text-pickle-ink">批次付款提醒結果</div>
          <ul class="mt-2 list-disc space-y-1 pl-5 text-xs">
            <% paymentReminderBatchFlash.lines.forEach(function (line) { %>
              <li><%= line %></li>
            <% }); %>
          </ul>
        </div>
      <% } %>

      <div class="mt-4 overflow-hidden rounded-3xl bg-white ring-1 ring-black/5">
        <div class="overflow-auto">
          <table class="min-w-full text-left text-sm">
            <thead class="bg-pickle-mist text-xs font-bold text-black/60">
              <tr>
                <% if (showPayPick) { %>
                  <th class="w-10 whitespace-nowrap px-2 py-3 text-center" title="勾選後按「對勾選者發送付款電郵」">
                    <input type="checkbox" id="selectAllUnpaid" class="h-4 w-4 rounded border-black/20 text-pickle-teal" aria-label="全選本頁未付款" />
                  </th>
                <% } %>
                <th class="whitespace-nowrap px-4 py-3">時間</th>
                <th class="whitespace-nowrap px-4 py-3">聯絡人</th>
                <th class="whitespace-nowrap px-4 py-3">電郵</th>
                <th class="whitespace-nowrap px-4 py-3">電話</th>
                <th class="whitespace-nowrap px-4 py-3">BOC</th>
                <th class="whitespace-nowrap px-4 py-3">組別</th>
                <th class="whitespace-nowrap px-4 py-3">付款</th>
                <th class="whitespace-nowrap px-4 py-3">球員 1</th>
                <th class="whitespace-nowrap px-4 py-3">球員 2</th>
                <th class="whitespace-nowrap px-4 py-3">電郵通知</th>
                <th class="whitespace-nowrap px-4 py-3">操作</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-black/5">
              <% (items || []).forEach(function (r) { %>
                <% const paidRow = (r.paymentStatus || "unpaid") === "paid"; %>
                <tr class="hover:bg-black/[0.02]">
                  <% if (showPayPick) { %>
                    <td class="px-2 py-3 text-center align-middle">
                      <input
                        type="checkbox"
                        name="registrationIds"
                        value="<%= r._id %>"
                        class="row-pay-cb h-4 w-4 rounded border-black/20 text-pickle-teal"
                        <%= paidRow ? "disabled" : "" %>
                        data-paid="<%= paidRow ? "1" : "0" %>"
                        aria-label="選取 <%= r.fullName || r.email %>"
                      />
                    </td>
                  <% } %>
                  <td class="whitespace-nowrap px-4 py-3 text-xs text-black/60">
                    <%= r.createdAt ? new Date(r.createdAt).toLocaleString("zh-HK", { hour12: false }) : "—" %>
                  </td>
                  <td class="whitespace-nowrap px-4 py-3 font-semibold text-pickle-ink">
                    <a class="hover:underline" href="/admin/registration/<%= r._id %>"><%= r.fullName || "—" %></a>
                  </td>
                  <td class="whitespace-nowrap px-4 py-3"><%= r.email || "—" %></td>
                  <td class="whitespace-nowrap px-4 py-3"><%= r.phone || "—" %></td>
                  <td class="whitespace-nowrap px-4 py-3 font-mono text-xs text-black/80"><%= (r.bocReferralCode && String(r.bocReferralCode).trim()) ? r.bocReferralCode : "-" %></td>
                  <td class="px-4 py-3 text-xs text-black/80"><%= (typeof divisionLabelOrValue === 'function' ? divisionLabelOrValue(r.division) : (r.division || "—")) %></td>
                  <td class="whitespace-nowrap px-4 py-3 text-xs font-semibold text-black/70">
                    <% const ps = r.paymentStatus || "unpaid"; %>
                    <%= ps === "paid" ? "已付款" : (ps === "pending" ? "待付款" : "未付款") %>
                  </td>
                  <td class="px-4 py-3 text-xs text-black/70">
                    <div class="font-semibold text-black/80"><%= r.player1?.name || "—" %></div>
                    <div>DUPR <%= duprOrNR(r.player1) %></div>
                  </td>
                  <td class="px-4 py-3 text-xs text-black/70">
                    <div class="font-semibold text-black/80"><%= r.player2?.name || "—" %></div>
                    <div>DUPR <%= duprOrNR(r.player2) %></div>
                  </td>
                  <td class="whitespace-nowrap px-4 py-3">
                    <span
                      class="inline-flex items-center rounded-full px-2 py-1 text-xs font-bold ring-1"
                      data-email-badge="<%= r._id %>"
                      data-email-sent="<%= r.emailSentAt ? 'sent' : (r.emailSendError ? 'failed' : 'pending') %>"
                      title="<%= r.emailSendError ? r.emailSendError : '' %>"
                    >
                      <%= r.emailSentAt ? '已發送' : (r.emailSendError ? '發送失敗' : '待發送') %>
                    </span>
                  </td>
                  <td class="whitespace-nowrap px-4 py-3">
                    <button
                      type="button"
                      class="rounded-xl bg-pickle-teal px-3 py-2 text-xs font-extrabold text-white hover:brightness-95"
                      data-check-email="<%= r._id %>"
                    >
                      檢查電郵
                    </button>
                  </td>
                </tr>
              <% }); %>
              <% if (!items || items.length === 0) { %>
                <tr>
                  <td class="px-4 py-8 text-center text-sm text-black/50" colspan="<%= tableColspan %>">暫無資料</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="mt-5 flex items-center justify-between">
        <div class="text-xs text-black/50">每頁 <%= pageSize %> 筆</div>
        <div class="flex gap-2">
          <% const totalPages = Math.max(1, Math.ceil((total || 0) / pageSize)); %>
          <a
            class="rounded-xl px-3 py-2 text-sm font-bold ring-1 ring-black/10 hover:bg-black/5 <%= page <= 1 ? 'pointer-events-none opacity-40' : '' %>"
            href="<%= typeof adminListPath === 'function' ? adminListPath({ page: Math.max(1, page - 1) }) : '/admin' %>"
          >
            上一頁
          </a>
          <a
            class="rounded-xl px-3 py-2 text-sm font-bold ring-1 ring-black/10 hover:bg-black/5 <%= page >= totalPages ? 'pointer-events-none opacity-40' : '' %>"
            href="<%= typeof adminListPath === 'function' ? adminListPath({ page: Math.min(totalPages, page + 1) }) : '/admin' %>"
          >
            下一頁
          </a>
        </div>
      </div>
      </form>
    </main>

    <script>
      (function () {
        function setBadgeStyle(badge, status) {
          if (!badge) return;
          badge.textContent = status;
          const s = String(status || '').toLowerCase();
          badge.classList.remove('bg-green-50','text-green-700','ring-green-200','bg-amber-50','text-amber-900','ring-amber-200','bg-slate-50','text-slate-700','ring-slate-200','bg-red-50','text-red-700','ring-red-200');
          if (s === '已發送') badge.classList.add('bg-green-50','text-green-700','ring-green-200');
          else if (s === '待發送') badge.classList.add('bg-amber-50','text-amber-900','ring-amber-200');
          else if (s === '發送失敗') badge.classList.add('bg-red-50','text-red-700','ring-red-200');
          else badge.classList.add('bg-slate-50','text-slate-700','ring-slate-200');
        }

        document.querySelectorAll('[data-email-badge]').forEach(function (b) {
          const sent = b.getAttribute('data-email-sent');
          if (sent === 'sent') setBadgeStyle(b, '已發送');
          else if (sent === 'failed') setBadgeStyle(b, '發送失敗');
          else setBadgeStyle(b, '待發送');
        });

        var selectAll = document.getElementById("selectAllUnpaid");
        if (selectAll) {
          selectAll.addEventListener("change", function () {
            var on = selectAll.checked;
            document.querySelectorAll(".row-pay-cb").forEach(function (cb) {
              if (cb.disabled) return;
              cb.checked = on;
            });
          });
        }

        document.querySelectorAll('[data-check-email]').forEach(function (btn) {
          btn.addEventListener('click', async function () {
            const id = btn.getAttribute('data-check-email');
            const badge = document.querySelector('[data-email-badge=\"' + id + '\"]');
            btn.disabled = true;
            const oldText = btn.textContent;
            btn.textContent = '檢查中...';
            try {
              const res = await fetch('/admin/registration/' + encodeURIComponent(id) + '/email-check', {
                credentials: 'same-origin',
                headers: { 'Accept': 'application/json' }
              });
              const ct = (res.headers.get('content-type') || '').toLowerCase();
              if (!res.ok || !ct.includes('application/json')) {
                alert('檢查失敗：請重新登入後再試。');
                return;
              }
              const data = await res.json();
              if (data && data.ok) {
                if (data.emailSentAt) setBadgeStyle(badge, '已發送');
                else if (data.emailSendError) setBadgeStyle(badge, '發送失敗');
                else setBadgeStyle(badge, '待發送');
              } else {
                alert('檢查失敗');
              }
            } catch (e) {
              alert('檢查失敗');
            } finally {
              btn.textContent = oldText;
              btn.disabled = false;
            }
          });
        });
      })();
    </script>
  </body>
</html>

