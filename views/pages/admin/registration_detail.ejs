<!doctype html>
<html lang="zh-HK">
  <head>
    <%- include("../../partials/head", { title: "後台 - 報名詳情 - " + tournament.name, tournament }) %>
    <style>
      body { font-family: "Noto Sans TC", system-ui, -apple-system, sans-serif; }
    </style>
  </head>
  <body>
    <header class="sticky top-0 z-40 border-b border-black/5 bg-white/80 backdrop-blur">
      <div class="mx-auto flex max-w-4xl items-center justify-between px-4 py-3">
        <div class="flex items-center gap-3">
          <img
            src="/images/picklevibes-logo.png"
            alt="PickleVibes"
            class="h-10 w-10 rounded-full bg-white object-contain ring-1 ring-black/5"
          />
          <div>
            <div class="text-sm font-extrabold text-pickle-ink">後台 · 報名詳情</div>
            <div class="text-xs text-black/60"><%= tournament.name %></div>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <a href="/admin" class="rounded-xl px-3 py-2 text-sm font-bold text-pickle-ink hover:bg-black/5">返回列表</a>
          <form method="post" action="/admin/logout">
            <button class="rounded-xl px-3 py-2 text-sm font-bold text-pickle-ink hover:bg-black/5" type="submit">
              登出
            </button>
          </form>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-4xl px-4 py-8">
      <% if (!reg) { %>
        <div class="rounded-3xl bg-white p-6 ring-1 ring-black/5">
          <div class="text-sm font-bold text-red-700">找不到資料</div>
        </div>
      <% } else { %>
        <div class="rounded-3xl bg-white p-6 ring-1 ring-black/5 md:p-8">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <div class="text-xs font-semibold text-black/60">提交時間</div>
              <div class="mt-1 text-sm font-extrabold text-pickle-ink">
                <%= reg.createdAt ? new Date(reg.createdAt).toLocaleString("zh-HK", { hour12: false }) : "—" %>
              </div>
            </div>
            <div class="text-right">
              <div class="text-xs font-semibold text-black/60">電郵通知</div>
              <div class="mt-1 text-sm font-extrabold text-pickle-ink">
                <% if (reg.emailSentAt) { %>已發送<% } else if (reg.emailSendError) { %>發送失敗<% } else { %>待發送<% } %>
              </div>
              <% if (reg.emailSendError) { %>
                <div class="mt-1 max-w-md text-xs text-red-700"><%= reg.emailSendError %></div>
              <% } %>
            </div>
          </div>

          <% if (typeof paymentFlash === "string" && paymentFlash) { %>
            <div class="mt-4 rounded-2xl bg-pickle-mist p-4 text-sm text-black/80 ring-1 ring-black/5"><%= paymentFlash %></div>
          <% } %>

          <div class="mt-6 rounded-3xl bg-white p-5 ring-1 ring-black/5">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <div class="text-sm font-extrabold text-pickle-ink">付款（Stripe）</div>
                <div class="mt-2 text-sm text-black/70">
                  狀態：<span class="font-bold text-pickle-ink"><%= (reg.paymentStatus || "unpaid") === "paid" ? "已付款" : ((reg.paymentStatus || "unpaid") === "pending" ? "待付款" : "未付款") %></span>
                </div>
                <% if (reg.paidAt) { %>
                  <div class="mt-1 text-xs text-black/55">
                    付款時間：<%= new Date(reg.paidAt).toLocaleString("zh-HK", { hour12: false }) %>
                  </div>
                <% } %>
                <% if (typeof divisionFeeCents === "function") { %>
                  <div class="mt-1 text-xs text-black/55">
                    應繳報名費（按組別）：HK$<%= (divisionFeeCents(reg.division) / 100).toFixed(2) %>
                  </div>
                <% } %>
              </div>
              <% if (typeof stripePaymentOk !== "undefined" && stripePaymentOk) { %>
                <form method="post" action="/admin/registration/<%= reg._id %>/send-payment-email" class="shrink-0">
                  <button
                    type="submit"
                    class="rounded-2xl bg-pickle-pink px-4 py-3 text-xs font-extrabold text-white shadow-sm hover:brightness-95"
                  >
                    發送付款電郵（Stripe）
                  </button>
                </form>
              <% } else { %>
                <div class="text-xs font-semibold text-red-700">Stripe 未設定：請設定 STRIPE_SECRET_KEY</div>
              <% } %>
            </div>
            <p class="mt-3 text-xs text-black/55">
              系統會建立 Stripe Checkout Session、寫入付款交易紀錄，並以電郵寄出付款連結。
            </p>
          </div>

          <div class="mt-6 grid gap-4 md:grid-cols-2">
            <div class="rounded-3xl bg-pickle-mist p-5 ring-1 ring-black/5">
              <div class="text-sm font-extrabold text-pickle-ink">聯絡人資料</div>
              <dl class="mt-4 grid gap-2 text-sm">
                <div class="flex items-start justify-between gap-4">
                  <dt class="text-black/60">姓名</dt>
                  <dd class="text-right font-semibold text-pickle-ink"><%= reg.fullName %></dd>
                </div>
                <div class="flex items-start justify-between gap-4">
                  <dt class="text-black/60">電郵</dt>
                  <dd class="text-right font-semibold text-pickle-ink"><%= reg.email %></dd>
                </div>
                <div class="flex items-start justify-between gap-4">
                  <dt class="text-black/60">電話</dt>
                  <dd class="text-right font-semibold text-pickle-ink"><%= reg.phone %></dd>
                </div>
                <% if (reg.bocReferralCode) { %>
                  <div class="flex items-start justify-between gap-4">
                    <dt class="text-black/60">推廣碼</dt>
                    <dd class="text-right font-semibold text-pickle-ink"><%= reg.bocReferralCode %></dd>
                  </div>
                <% } %>
                <div class="flex items-start justify-between gap-4">
                  <dt class="text-black/60">組別</dt>
                  <dd class="text-right text-xs font-semibold text-pickle-ink md:text-sm"><%= typeof divisionLabelOrValue === 'function' ? divisionLabelOrValue(reg.division) : reg.division %></dd>
                </div>
              </dl>
            </div>

            <div class="rounded-3xl bg-white p-5 ring-1 ring-black/5">
              <div class="text-sm font-extrabold text-pickle-ink">賽事資訊</div>
              <dl class="mt-4 grid gap-2 text-sm">
                <div class="flex items-start justify-between gap-4">
                  <dt class="text-black/60">比賽</dt>
                  <dd class="text-right font-semibold text-pickle-ink"><%= reg.tournamentName %></dd>
                </div>
                <div class="flex items-start justify-between gap-4">
                  <dt class="text-black/60">日期</dt>
                  <dd class="text-right font-semibold text-pickle-ink"><%= reg.tournamentDate %></dd>
                </div>
                <div class="flex items-start justify-between gap-4">
                  <dt class="text-black/60">地點</dt>
                  <dd class="text-right font-semibold text-pickle-ink"><%= reg.tournamentLocation %></dd>
                </div>
              </dl>
            </div>
          </div>

          <div class="mt-4 grid gap-4 md:grid-cols-2">
            <div class="rounded-3xl bg-pickle-mist p-5 ring-1 ring-black/5">
              <div class="text-sm font-extrabold text-pickle-ink">球員 1</div>
              <div class="mt-3 text-sm text-black/80">
                <div><span class="text-black/50">姓名：</span><span class="font-semibold text-pickle-ink"><%= reg.player1?.name || "—" %></span></div>
                <div class="mt-1"><span class="text-black/50">出生日期：</span><%= reg.player1?.dateOfBirth ? new Date(reg.player1.dateOfBirth).toISOString().slice(0, 10) : "—" %></div>
                <div class="mt-1"><span class="text-black/50">性別：</span><%= reg.player1?.gender === "male" ? "男" : (reg.player1?.gender === "female" ? "女" : "—") %></div>
                <div class="mt-1"><span class="text-black/50">DUPR：</span><%= duprOrNR(reg.player1) %></div>
              </div>
            </div>
            <div class="rounded-3xl bg-pickle-mist p-5 ring-1 ring-black/5">
              <div class="text-sm font-extrabold text-pickle-ink">球員 2</div>
              <div class="mt-3 text-sm text-black/80">
                <div><span class="text-black/50">姓名：</span><span class="font-semibold text-pickle-ink"><%= reg.player2?.name || "—" %></span></div>
                <div class="mt-1"><span class="text-black/50">出生日期：</span><%= reg.player2?.dateOfBirth ? new Date(reg.player2.dateOfBirth).toISOString().slice(0, 10) : "—" %></div>
                <div class="mt-1"><span class="text-black/50">性別：</span><%= reg.player2?.gender === "male" ? "男" : (reg.player2?.gender === "female" ? "女" : "—") %></div>
                <div class="mt-1"><span class="text-black/50">DUPR：</span><%= duprOrNR(reg.player2) %></div>
              </div>
            </div>
          </div>

          <% if (reg.notes) { %>
            <div class="mt-4 rounded-3xl bg-white p-5 ring-1 ring-black/5">
              <div class="text-sm font-extrabold text-pickle-ink">備註</div>
              <div class="mt-2 whitespace-pre-wrap text-sm text-black/70"><%= reg.notes %></div>
            </div>
          <% } %>
        </div>
      <% } %>
    </main>
  </body>
</html>

