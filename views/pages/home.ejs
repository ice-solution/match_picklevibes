<!doctype html>
<html lang="zh-HK">
  <head>
    <%- include("../partials/head", { title: tournament.name, tournament }) %>
    <style>
      body { font-family: "Noto Sans TC", system-ui, -apple-system, sans-serif; }
    </style>
  </head>
  <body>
    <%- include("../partials/nav", { tournament }) %>
    <%- include("../partials/banner", { tournament }) %>

    <main class="mx-auto max-w-6xl px-4 py-10">
      <div class="grid gap-6 md:grid-cols-12">
        <section class="md:col-span-7">
          <h2 class="text-xl font-extrabold tracking-tight text-pickle-ink">流程</h2>
          <div class="mt-4 grid gap-3">
            <div class="rounded-2xl bg-white p-5 ring-1 ring-black/5">
              <div class="text-sm font-bold text-pickle-ink">1) 填表</div>
              <div class="mt-1 text-sm text-black/70">填寫聯絡資料、兩位球員資料（姓名、出生日期、性別、DUPR）及組別。</div>
            </div>
            <div class="rounded-2xl bg-white p-5 ring-1 ring-black/5">
              <div class="text-sm font-bold text-pickle-ink">2) 確認電郵</div>
              <div class="mt-1 text-sm text-black/70">系統會核對組別與球員資料；提交後會以電郵確認，稍後再通知抽籤結果及付款連結。</div>
            </div>
          </div>

          <% if (typeof registrationDeadline !== 'undefined' && registrationDeadline) { %>
            <p class="mt-4 text-sm font-semibold text-pickle-teal">
              截止報名：<%= new Date(registrationDeadline).toLocaleString("zh-HK", { hour12: false }) %>
            </p>
          <% } %>
          <% if (typeof registrationOpen !== 'undefined' && !registrationOpen) { %>
            <p class="mt-2 text-sm font-bold text-red-600">報名已截止</p>
          <% } %>

          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href="/apply"
              class="inline-flex items-center justify-center rounded-2xl bg-pickle-pink px-5 py-3 text-sm font-bold text-white shadow-sm hover:brightness-95 <%= typeof registrationOpen !== 'undefined' && !registrationOpen ? 'pointer-events-none opacity-50' : '' %>"
            >
              <%= typeof registrationOpen !== 'undefined' && !registrationOpen ? '報名已截止' : '前往申請表' %>
            </a>
          </div>
        </section>

        <aside class="md:col-span-5">
          <div class="rounded-3xl bg-white p-6 ring-1 ring-black/5">
            <div class="text-sm font-bold text-pickle-ink">比賽資訊</div>
            <dl class="mt-4 grid gap-3 text-sm">
              <div class="flex items-start justify-between gap-4">
                <dt class="text-black/60">名稱</dt>
                <dd class="text-right font-semibold text-pickle-ink"><%= tournament.name %></dd>
              </div>
              <div class="flex items-start justify-between gap-4">
                <dt class="text-black/60">日期</dt>
                <dd class="text-right font-semibold text-pickle-ink"><%= tournament.date %></dd>
              </div>
              <div class="flex items-start justify-between gap-4">
                <dt class="text-black/60">地點</dt>
                <dd class="text-right font-semibold text-pickle-ink"><%= tournament.location %></dd>
              </div>
            </dl>
            <div class="mt-6 rounded-2xl bg-pickle-mist p-4 ring-1 ring-black/5">
              <div class="text-xs font-semibold text-black/60">提示</div>
              <div class="mt-1 text-sm text-black/70">
                DUPR 須介乎 2.00–4.00（小數點後 2 位）。如沒有 DUPR 可 tick NR（只限公開組及 3.0- 組別）。系統會按組別核對年齡、DUPR 與性別要求。
              </div>
            </div>
          </div>
        </aside>
      </div>
    </main>
  </body>
</html>

