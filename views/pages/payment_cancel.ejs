<!doctype html>
<html lang="zh-HK">
  <head>
    <%- include("../partials/head", { title: "未完成付款 - " + tournament.name, tournament }) %>
    <style>
      body { font-family: "Noto Sans TC", system-ui, -apple-system, sans-serif; }
    </style>
  </head>
  <body>
    <%- include("../partials/nav", { tournament }) %>
    <main class="mx-auto max-w-xl px-4 py-12">
      <div class="rounded-3xl bg-white p-6 ring-1 ring-black/5 md:p-8">
        <div class="text-xl font-extrabold text-pickle-ink">尚未完成付款</div>
        <p class="mt-3 text-sm leading-relaxed text-black/70">
          你已取消或未完成 Stripe 付款。請留意主辦方稍後發出的付款電郵，或在成功付款後保留 Stripe 收據。
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/" class="inline-flex rounded-2xl bg-pickle-mist px-5 py-3 text-sm font-extrabold text-pickle-ink ring-1 ring-black/5 hover:bg-black/5">返回首頁</a>
          <% if (rid) { %>
            <a href="/success?rid=<%= rid %>" class="inline-flex rounded-2xl bg-pickle-teal px-5 py-3 text-sm font-extrabold text-white hover:brightness-95">查看報名紀錄</a>
          <% } %>
        </div>
      </div>
    </main>
  </body>
</html>
